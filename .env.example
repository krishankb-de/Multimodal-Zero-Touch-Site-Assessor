# ─── Required ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Pioneer SLM (optional — rule-based fallback used if not set) ────────────
PIONEER_API_KEY=your_pioneer_api_key_here
PIONEER_API_URL=https://api.pioneer.ai/v1
PIONEER_MODEL=deepseek-ai/DeepSeek-V3.1

# ─── Gemini model ─────────────────────────────────────────────────────────────
GEMINI_MODEL_NAME=gemini-2.5-flash

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG

# ─── Market / region ──────────────────────────────────────────────────────────
DEFAULT_MARKET=DE
DEFAULT_CURRENCY=EUR
REGION=Hamburg   # Brandenburg | Hamburg | North Germany | Ruhr

# ─── 3D reconstruction ────────────────────────────────────────────────────────
RECONSTRUCTION_BUDGET_S=90    # seconds before SfM falls back to next tier
VISION_PROVIDER=gemini        # gemini | pioneer


